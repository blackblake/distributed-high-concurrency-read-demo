<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hw1.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.example.hw1.domain.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.hw1.domain.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (name, price, stock, description, status)
        VALUES (#{name}, #{price}, #{stock}, #{description}, #{status})
    </insert>

    <update id="update" parameterType="com.example.hw1.domain.Product">
        UPDATE product
        SET
            name = #{name},
            price = #{price},
            stock = #{stock},
            description = #{description},
            status = #{status}
        WHERE id = #{id}
    </update>

    <select id="findById" resultMap="ProductResultMap">
        SELECT id, name, price, stock, description, status, create_time, update_time
        FROM product
        WHERE id = #{id}
    </select>
</mapper>
